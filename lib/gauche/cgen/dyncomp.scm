(define-module gauche.cgen.dyncomp
  (use gauche.cgen)
  (use gauche.package.compile)
  (use gauche.config)
  (use file.util)
  (export cgen-dynamic-load))
(select-module gauche.cgen.dyncomp)

;; This module provides a convenient way to generate C code, compile, link,
;; and dynamically load on-the-fly.

;; Entry point
;;   `unit` is a <cgen-unit>
;;   `tmpdir` is the parent of the temporary work directory created here.
;;
;; Unit's c-file slot is overridden with the temporary C file name
;; generated by cgen-dynamic-load.

(define (cgen-dynamic-load unit :optional (tmpdir (sys-tmpdir)))
  (let* ([workdir (sys-mkdtemp (build-path tmpdir (cgen-safe-name (~ unit'name))))]
         [c-file  ($ build-path workdir
                     $ string-append (cgen-safe-name (~ unit'name)) ".c")]
         [o-file  (path-swap-extension c-file (gauche-config "--object-suffix"))]
         [so-file (path-swap-extension c-file (gauche-config "--so-suffix"))])
    (set! (~ unit'c-file) c-file)

    ;; Generate C file, compile, and link.
    (cgen-emit-c unit)
    (gauche-package-compile (sys-basename c-file)
                            :srcdir   workdir
                            :output   o-file)
    (gauche-package-link so-file (list o-file))

    (let1 dlo (dynamic-load (path-sans-extension so-file)
                            :init-function (cgen-unit-init-name unit))
      ;; Arrange cleanup
      (sys-unlink c-file)
      (sys-unlink o-file)
      (sys-unlink-eventually dlo so-file 1))))
