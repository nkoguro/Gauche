srcdir       = @srcdir@
top_builddir = @top_builddir@
top_srcdir   = @top_srcdir@

include ../Makefile.ext

SCM_CATEGORY = gauche

LIBFILES = gauche--btype.$(SOEXT)
SCMFILES = btype.sci ffi.scm ffi/stubgen.scm ffi/native.scm

OBJECTS = $(gauche_btype_OBJECTS)

CONFIG_GENERATED = Makefile
PREGENERATED =
XCLEANFILES = gauche--btype.c btype.sci \
	      f.$(OBJEXT) f.$(SOEXT) \
	      g.$(OBJEXT) g.$(SOEXT)

all : $(LIBFILES) f.$(SOEXT) g.$(SOEXT)

gauche_btype_OBJECTS = gauche--btype.$(OBJEXT)

gauche--btype.$(SOEXT) : $(gauche_btype_OBJECTS)
	$(MODLINK) gauche--btype.$(SOEXT) $(gauche_btype_OBJECTS) $(EXT_LIBGAUCHE) $(LIBS)

gauche--btype.c btype.sci : btype.scm
	$(PRECOMP) -e -P -o gauche--btype $(srcdir)/btype.scm

f.$(SOEXT): c/f.h c/f.c
	$(COMPILE) -c -I $(srcdir)/c $(srcdir)/c/f.c -o f.$(OBJEXT)
	$(LINK) f.$(SOEXT) f.$(OBJEXT)

g.$(SOEXT): c/g.c
	$(COMPILE) -c -I $(srcdir)/c $(srcdir)/c/g.c -o g.$(OBJEXT)
	$(LINK) g.$(SOEXT) g.$(OBJEXT) $(EXT_LIBGAUCHE) $(LIBS)


install : install-std
