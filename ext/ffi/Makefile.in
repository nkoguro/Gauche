srcdir       = @srcdir@
top_builddir = @top_builddir@
top_srcdir   = @top_srcdir@

include ../Makefile.ext

SCM_CATEGORY = gauche

LIBFILES = gauche--ctype.$(SOEXT)
SCMFILES = ctype.sci ffi.scm ffi/stubgen.scm ffi/native.scm

OBJECTS = $(gauche_ctype_OBJECTS)

CONFIG_GENERATED = Makefile
PREGENERATED =
XCLEANFILES = gauche--ctype.c ctype.sci \
	      f.$(OBJEXT) f.$(SOEXT) \
	      g.$(OBJEXT) g.$(SOEXT)

all : $(LIBFILES) f.$(SOEXT) g.$(SOEXT)

gauche_ctype_OBJECTS = gauche--ctype.$(OBJEXT)

gauche--ctype.$(SOEXT) : $(gauche_ctype_OBJECTS)
	$(MODLINK) gauche--ctype.$(SOEXT) $(gauche_ctype_OBJECTS) $(EXT_LIBGAUCHE) $(LIBS)

gauche--ctype.c ctype.sci : ctype.scm
	$(PRECOMP) -e -P -o gauche--ctype $(srcdir)/ctype.scm

f.$(SOEXT): c/f.h c/f.c
	$(COMPILE) -c -I $(srcdir)/c $(srcdir)/c/f.c -o f.$(OBJEXT)
	$(LINK) f.$(SOEXT) f.$(OBJEXT)

g.$(SOEXT): c/g.c
	$(COMPILE) -c -I $(srcdir)/c $(srcdir)/c/g.c -o g.$(OBJEXT)
	$(LINK) g.$(SOEXT) g.$(OBJEXT) $(EXT_LIBGAUCHE) $(LIBS)


install : install-std
